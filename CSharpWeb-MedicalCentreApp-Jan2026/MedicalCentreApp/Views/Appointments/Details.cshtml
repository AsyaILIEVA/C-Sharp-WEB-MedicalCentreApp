@model MedicalCentreApp.ViewModels.Appointments.AppointmentDetailsViewModel
@* @model MedicalCentreApp.ViewModels.Prescriptions.PrescriptionListViewModel *@

<h2>Appointment Details</h2>

<p>@Model.Date.ToString("dd MMM yyyy, HH:mm")</p>
<p><strong>Patient:</strong> @Model.PatientName</p>
<p><strong>Doctor:</strong> @Model.DoctorName</p>
<p><strong>Status:</strong> @Model.Status</p>
<p><strong>Reason:</strong> @Model.Reason</p>

@if (Model.HasMedicalRecord)
{
    <span class="badge bg-success">Medical record available</span>
}
else
{
    <span class="badge bg-warning">No medical record yet</span>
}

<hr />

<h4>Medical Record</h4>

@if (!Model.HasMedicalRecord)
{
    <a asp-controller="MedicalRecords"
       asp-action="Create"
       asp-route-appointmentId="@Model.Id"
       class="btn btn-success">
        Create Medical Record
    </a>
}
else
{
    <div class="card mt-3 shadow-sm">
        <div class="card-body">
            <p><strong>Diagnosis:</strong> @Model.Diagnosis</p>
            @if (Model.Prescriptions != null && Model.Prescriptions.Any())
            {
                <ul class="list-group mt-2">
                    @foreach (var prescription in Model.Prescriptions)
                    {
                        <li class="list-group-item">
                            <strong>@prescription.MedicationName</strong> -
                            @prescription.Dosage
                            <br />
                            <small class="text-muted">
                                Issued on: @prescription.IssuedOn.ToString("dd MMM yyyy")
                            </small>
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted">No prescriptions available.</p>
            }
        </div>
    </div>
}

