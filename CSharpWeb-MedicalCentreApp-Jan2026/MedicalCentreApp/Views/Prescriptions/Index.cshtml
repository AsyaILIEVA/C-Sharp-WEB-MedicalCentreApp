@model IEnumerable<MedicalCentreApp.ViewModels.Prescriptions.PrescriptionListViewModel>

@{
    ViewData["Title"] = "Prescriptions";
}

<h2 class="mb-4">Prescriptions</h2>

@if (User.IsInRole("Administrator") || User.IsInRole("Doctor"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">
            Create Prescription
        </a>
    </p>
}

@if (!Model.Any())
{
    <div class="alert alert-warning">
        No prescriptions found.
    </div>
}
else
{
    <table class="table table-striped table-bordered shadow-sm">
        <thead class="table-light">
            <tr>
                <th>Medication</th>
                <th>Dosage</th>
                <th>Issued On</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var prescription in Model)
            {
                <tr>
                    <td>@prescription.MedicationName</td>
                    <td>@prescription.Dosage</td>
                    <td>@prescription.IssuedOn.ToString("dd MMM yyyy")</td>
                    <td>
                        <a asp-action="Details"
                           asp-route-id="@prescription.Id"
                           class="btn btn-sm btn-info">
                            Details
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}