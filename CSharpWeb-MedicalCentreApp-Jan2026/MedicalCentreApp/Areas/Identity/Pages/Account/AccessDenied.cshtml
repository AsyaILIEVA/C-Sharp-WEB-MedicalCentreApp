@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Access denied";
}

<header>
    <h1 class="text-danger">@ViewData["Title"]</h1>
    <p class="text-danger">You do not have permission to access this page.</p>
    <a asp-area=""
       asp-controller="Home"
       asp-action="Index"
       class="btn btn-primary">
        Return Home
    </a>
</header>
