@model MedicalCentreApp.ViewModels.Invoices.CreateInvoiceViewModel

<h2>Create Invoice</h2>

<form asp-area="Administrator"
      asp-controller="InvoicesManagement"
      asp-action="Create"
      method="post">

    <div class="mb-3">
        <label class="form-label">Amount</label>
        <input asp-for="Amount" class="form-control" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Appointment Id</label>
        <input asp-for="AppointmentId" class="form-control" />
        <span asp-validation-for="AppointmentId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Create</button>

    <a asp-area="Administrator"
       asp-controller="InvoicesManagement"
       asp-action="Index"
       class="btn btn-secondary">
        Cancel
    </a>
</form>